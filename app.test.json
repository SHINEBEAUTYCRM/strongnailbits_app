{
  "expo": {
    "name": "ShineShop B2B",
    "slug": "shineshop-b2b",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "shineshop",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "bundleIdentifier": "com.shineshop.b2b",
      "supportsTablet": true,
      "buildNumber": "7",
      "associatedDomains": [
        "applinks:shineshopb2b.com"
      ],
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleDevelopmentRegion": "uk",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Shine Shop потребує доступ до фотогалереї для завантаження фото профілю та відгуків",
        "NSCameraUsageDescription": "Shine Shop потребує доступ до камери для сканування штрих-кодів товарів"
      }
    },
    "android": {
      "package": "com.shineshop.b2b",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "shineshopb2b.com",
              "pathPrefix": "/product"
            },
            {
              "scheme": "https",
              "host": "shineshopb2b.com",
              "pathPrefix": "/catalog"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c186aa6a-d95a-4d5f-8b31-60eed7afb5e0"
      }
    },
    "owner": "shineshopb2b"
  }
}