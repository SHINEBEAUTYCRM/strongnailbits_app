{
  "expo": {
    "name": "Strong Nail Bits",
    "slug": "strongnailbits",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "strongnailbits",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "bundleIdentifier": "com.strongnailbits.app",
      "supportsTablet": true,
      "buildNumber": "7",
      "associatedDomains": [
        "applinks:shineshopb2b.com",
        "applinks:shineshopb2b.com"
      ],
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleDevelopmentRegion": "uk",
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Strong Nail Bits потребує доступ до фотогалереї для завантаження фото профілю та відгуків",
        "NSCameraUsageDescription": "Strong Nail Bits потребує доступ до камери для сканування штрих-кодів товарів"
      }
    },
    "android": {
      "package": "com.strongnailbits.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "shineshopb2b.com",
              "pathPrefix": "/product"
            },
            {
              "scheme": "https",
              "host": "shineshopb2b.com",
              "pathPrefix": "/catalog"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "shineshopb2b.com",
              "pathPrefix": "/product"
            },
            {
              "scheme": "https",
              "host": "shineshopb2b.com",
              "pathPrefix": "/catalog"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-apple-authentication",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "aleksdandali"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f68cb9f9-735b-407b-b71f-d119328869ad"
      }
    },
    "owner": "shineshopb2b",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/f68cb9f9-735b-407b-b71f-d119328869ad"
    }
  }
}
